<!DOCTYPE html>
<html lang="nl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mnemonic Wallet & Private Key Extractor</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            background-color: #f4f4f9;
            color: #333;
            margin: 0;
            padding: 20px;
        }
        .container {
            max-width: 800px;
            margin: 0 auto;
            background: #fff;
            padding: 20px;
            box-shadow: 0 0 10px rgba(0,0,0,0.1);
            border-radius: 8px;
        }
        h2 { text-align: center; color: #1e88e5; }
        .input-group { margin-bottom: 15px; }
        label { display: block; margin-bottom: 5px; font-weight: bold; }
        textarea {
            width: 100%;
            height: 80px;
            padding: 10px;
            border: 1px solid #ccc;
            border-radius: 4px;
            font-size: 16px;
            box-sizing: border-box;
        }
        button {
            display: block;
            width: 100%;
            padding: 12px;
            background-color: #1e88e5;
            color: white;
            border: none;
            border-radius: 4px;
            font-size: 18px;
            cursor: pointer;
        }
        button:hover { background-color: #1565c0; }
        #result { margin-top: 20px; padding: 15px; background: #eee; border-radius: 4px; word-break: break-all; }
        .error { color: red; font-weight: bold; }
        .key-box { background: #fff; padding: 10px; border-left: 5px solid #ff9800; margin: 10px 0; font-family: monospace; }
    </style>
</head>
<body>

<div class="container">
    <h2>Mnemonic Wallet & Private Key Extractor</h2>
    <div class="input-group">
        <label for="phrase">Vul jouw 12 of 24 woorden in (gescheiden door een spatie):</label>
        <textarea id="phrase" placeholder="bijv: apple banana cat dog ..."></textarea>
    </div>
    
    <button onclick="processPhrase()">Genereer Private Key & Check Balance</button>

    <div id="result"></div>
</div>

<script src="https://cloudflare.com"></script>
<script>
    async function processPhrase() {
        const phraseInput = document.getElementById('phrase').value.trim();
        const resultDiv = document.getElementById('result');
        resultDiv.innerHTML = 'Bezig met verwerken en verifiëren...';

        const words = phraseInput.split(/\s+/);
        if (words.length !== 12 && words.length !== 24) {
            resultDiv.innerHTML = '<span class="error">Fout: Een secret phrase moet precies 12 of 24 woorden bevatten.</span>';
            return;
        }

        try {
            // Genereer de wallet op basis van de ingevoerde mnemonic
            const wallet = ethers.Wallet.fromMnemonic(phraseInput);
            
            // Haal de cruciale gegevens op
            const address = wallet.address;
            const privateKey = wallet.privateKey; // Dit is de werkende private key

            // Haal de balans op via de publieke Etherscan API
            const apiUrl = `https://etherscan.io{address}&tag=latest&apikey=UwEtherscanAPIKeyHier`;
            
            let balanceEth = "0.0";
            try {
                const response = await fetch(apiUrl);
                const data = await response.json();
                if (data.status === "1") {
                    balanceEth = ethers.utils.formatEther(data.result);
                }
            } catch (apiError) {
                console.log("Kon balans niet ophalen via API, toon alleen de sleutels.");
                balanceEth = "Onbekend (API fout)";
            }

            // Toon de resultaten inclusief de werkende private key
            resultDiv.innerHTML = `
                <p><strong>Publiek Adres:</strong><br> ${address}</p>
                
                <p><strong>Gekoppelde Werkende Private Key:</strong></p>
                <div class="key-box">${privateKey}</div>
                <small style="color: #666;">(Deze sleutel kan direct in MetaMask of Trust Wallet geïmporteerd worden via 'Import Account')</small>
                
                <p style="margin-top:15px;"><strong>Ethereum Balance:</strong> ${balanceEth} ETH</p>
            `;

        } catch (error) {
            resultDiv.innerHTML = '<span class="error">Ongeldige secret phrase. Controleer of alle woorden correct gespeld zijn volgens de BIP39-lijst.</span>';
            console.error(error);
        }
    }
</script>

</body>
</html>
